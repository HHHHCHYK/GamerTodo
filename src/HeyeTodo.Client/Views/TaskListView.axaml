<!-- 任务列表视图：上部分工具栏（项目/搜索/筛选/排序/项目CRUD），下部分左右分栏（任务列表 + 编辑面板） -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="HeyeTodo.Client.Views.TaskListView"
             x:DataType="vm:TaskListViewModel">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="2*,1.1*" RowSpacing="12" ColumnSpacing="12">

        <!-- ===== 顶部工具栏卡片（跨两列）===== -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="16"
                Background="{StaticResource CozyCardBrush}"
                BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
            <StackPanel Spacing="10">
                <TextBlock Text="{loc:T Key=Nav.Tasks}" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource CozyTextBrush}"/>

                <!-- 第 1 行控件：项目选择 | 刷新 | 搜索 | 状态筛选 | 排序 | 新建任务 -->
                <Grid ColumnDefinitions="2*,Auto,2*,Auto,Auto,Auto" ColumnSpacing="8">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProjectItemViewModel">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Content="{loc:T Key=Tasks.Refresh}" Command="{Binding RefreshCommand}"/>
                    <TextBox Grid.Column="2" Text="{Binding SearchText}" PlaceholderText="{loc:T Key=Tasks.Search}"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskStatusOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskSortOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="5" Content="{loc:T Key=Tasks.CreateTask}" Command="{Binding NewTaskCommand}"
                            IsEnabled="{Binding HasSelectedProject}" Classes="accent"/>
                </Grid>

                <!-- 第 2 行控件：项目名称 | 描述 | 包含已完成 | 创建项目 | 保存项目 -->
                <Grid ColumnDefinitions="2*,2*,Auto,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0" Text="{Binding ProjectName}" PlaceholderText="{loc:T Key=Projects.Name}"/>
                    <TextBox Grid.Column="1" Text="{Binding ProjectDescription}" PlaceholderText="{loc:T Key=Projects.Description}"/>
                    <CheckBox Grid.Column="2" Content="{loc:T Key=Tasks.IncludeCompleted}" IsChecked="{Binding IncludeCompleted}" VerticalAlignment="Center"/>
                    <Button Grid.Column="3" Content="{loc:T Key=Tasks.CreateProject}" Command="{Binding CreateProjectCommand}"/>
                    <Button Grid.Column="4" Content="{loc:T Key=Tasks.SaveProject}" Command="{Binding SaveProjectCommand}" IsEnabled="{Binding HasSelectedProject}"/>
                </Grid>

                <!-- 删除项目按钮（右对齐） -->
                <Button Content="{loc:T Key=Tasks.DeleteProject}" Command="{Binding DeleteProjectCommand}"
                        HorizontalAlignment="Right" IsEnabled="{Binding HasSelectedProject}"/>

                <!-- 状态 / 错误消息 -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource CozySuccessBrush}"
                           IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CozyErrorBrush}"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
        </Border>

        <!-- ===== 左列：任务列表卡片 ===== -->
        <Border Grid.Row="1" Grid.Column="0" Padding="14"
                Background="{StaticResource CozyCardBrush}"
                BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:T Key=Tasks.List}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource CozyTextBrush}"/>
                    <TextBlock Text="{loc:T Key=Tasks.NoProject}" Foreground="{StaticResource CozyTextMutedBrush}"
                               IsVisible="{Binding ShowNoProjectMessage}"/>
                    <TextBlock Text="{loc:T Key=Tasks.Empty}" Foreground="{StaticResource CozyTextMutedBrush}"
                               IsVisible="{Binding ShowEmptyTasksMessage}"/>
                </StackPanel>

                <ListBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding SelectedTask}" IsVisible="{Binding ShowTaskList}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskItemViewModel">
                            <!-- 任务卡片：左侧 4px 强调色条，右侧下一状态按钮 -->
                            <Border Padding="10" Margin="0,0,0,6"
                                    Background="{StaticResource CozyBgBrush}"
                                    BorderBrush="{StaticResource CozyBorderBrush}"
                                    BorderThickness="0,0,0,2" CornerRadius="8">
                                <Grid ColumnDefinitions="4,*,Auto" RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="4" ColumnSpacing="10">
                                    <Border Grid.Column="0" Grid.RowSpan="3" Width="4" CornerRadius="2"
                                            Background="{StaticResource CozyAccentBrush}"/>
                                    <!-- 标题 -->
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold"
                                               Foreground="{StaticResource CozyTextBrush}"/>
                                    <!-- 下一状态按钮：通过 $parent 绑定到父级 UserControl 的 DataContext -->
                                    <Button Grid.Column="2" Content="{loc:T Key=Tasks.NextStatus}"
                                            Command="{Binding $parent[UserControl].DataContext.AdvanceTaskStatusCommand}"
                                            CommandParameter="{Binding}"/>

                                    <!-- 标签行：状态 + 优先级 + 排期 -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Border Background="{StaticResource CozyListSelectedBrush}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                                       Foreground="{StaticResource CozyTextBrush}"/>
                                        </Border>
                                        <Border Background="{StaticResource CozyMintBrush}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding PriorityLabel}" FontSize="11"
                                                       Foreground="{StaticResource CozyTextBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding ScheduleLabel}" FontSize="11"
                                                   Foreground="{StaticResource CozyTextMutedBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- 描述（仅非空时显示） -->
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Description}"
                                               Foreground="{StaticResource CozyTextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ===== 右列：任务编辑卡片 ===== -->
        <Border Grid.Row="1" Grid.Column="1" Padding="16"
                Background="{StaticResource CozyCardBrush}"
                BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
            <StackPanel Spacing="10">
                <TextBlock Text="{loc:T Key=Tasks.Editor}" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource CozyTextBrush}"/>
                <!-- 未选中任务时的占位提示 -->
                <TextBlock Text="{loc:T Key=Tasks.EditorEmpty}" Foreground="{StaticResource CozyTextMutedBrush}"
                           IsVisible="{Binding !ShowEditorForm}"/>

                <!-- 编辑表单：标题 / 描述 / 状态+优先级 / 开始+结束日期 / 预估工时 / 操作按钮 -->
                <StackPanel Spacing="8" IsVisible="{Binding ShowEditorForm}">
                    <TextBox Text="{Binding EditTitle}" PlaceholderText="{loc:T Key=Tasks.Editor.Title}"/>
                    <TextBox Text="{Binding EditDescription}" PlaceholderText="{loc:T Key=Tasks.Editor.Description}"
                             AcceptsReturn="True" MinHeight="80"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <ComboBox Grid.Column="0" ItemsSource="{Binding EditorStatuses}" SelectedItem="{Binding EditStatus}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaskStatusOption">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding EditorPriorities}" SelectedItem="{Binding EditPriority}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaskPriorityOption">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding EditStartDate}" PlaceholderText="{loc:T Key=Tasks.Editor.StartDate}"/>
                        <TextBox Grid.Column="1" Text="{Binding EditEndDate}" PlaceholderText="{loc:T Key=Tasks.Editor.EndDate}"/>
                    </Grid>

                    <TextBox Text="{Binding EditEstimatedHours}" PlaceholderText="{loc:T Key=Tasks.Editor.EstimatedHours}"/>

                    <!-- 底部操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="{loc:T Key=Common.Cancel}" Command="{Binding CancelEditCommand}"/>
                        <Button Content="{loc:T Key=Tasks.Delete}" Command="{Binding DeleteTaskCommand}" IsEnabled="{Binding HasSelectedTask}"/>
                        <Button Content="{loc:T Key=Common.Save}" Command="{Binding SaveTaskCommand}" Classes="accent"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
