<!-- 启动闪屏窗口：固定大小、无边框，展示品牌 Logo、加载进度条和状态消息 -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HeyeTodo.Client.ViewModels"
        xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
        x:Class="HeyeTodo.Client.Views.SplashWindow"
        x:DataType="vm:SplashViewModel"
        Width="420" Height="240"
        CanResize="False"
        WindowDecorations="BorderOnly"
        Title="{loc:T Key=App.Title}">

    <Border Background="{StaticResource CozyBgBrush}" Padding="28">
        <StackPanel VerticalAlignment="Center" Spacing="12">
            <!-- 品牌标题与副标题 -->
            <TextBlock Text="★ HeyeTodo ★" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource CozyAccentBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{loc:T Key=App.Tagline}" HorizontalAlignment="Center"
                       Foreground="{StaticResource CozyTextMutedBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>

            <!-- 加载进度条：无错误时显示，不确定模式 -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNull}}"/>

            <!-- 当前加载状态文本 -->
            <TextBlock Text="{Binding Status}" HorizontalAlignment="Center"
                       Foreground="{StaticResource CozyTextMutedBrush}" FontSize="12"/>
            <!-- 错误消息：有错时替换进度条和状态文本 -->
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                       TextWrapping="Wrap" Foreground="{StaticResource CozyErrorBrush}"/>
        </StackPanel>
    </Border>

</Window>
