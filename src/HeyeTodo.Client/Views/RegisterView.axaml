<!-- 注册页面：居中的卡片式布局，包含邮箱/昵称/密码输入，注册与返回按钮 -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="HeyeTodo.Client.Views.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <!-- 全屏背景 -->
    <Border Background="{StaticResource CozyBgBrush}">
        <!-- 注册卡片：固定最大宽度 360，居中 -->
        <Border MaxWidth="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="28" Background="{StaticResource CozyCardBrush}"
                BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="12">
            <StackPanel Spacing="14">
                <!-- 页面标题 -->
                <TextBlock Text="{loc:T Key=Auth.Register}" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource CozyAccentBrush}" HorizontalAlignment="Center"/>

                <!-- 邮箱输入 -->
                <TextBox PlaceholderText="{loc:T Key=Auth.Email}" Text="{Binding Email}"/>
                <!-- 显示名称输入 -->
                <TextBox PlaceholderText="{loc:T Key=Auth.DisplayName}" Text="{Binding DisplayName}"/>
                <!-- 密码输入（掩码显示） -->
                <TextBox PlaceholderText="{loc:T Key=Auth.Password}" Text="{Binding Password}" PasswordChar="*"/>

                <!-- 错误消息 -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CozyErrorBrush}"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <!-- 注册按钮：忙时禁用 -->
                <Button Content="{loc:T Key=Auth.Register}" Command="{Binding RegisterCommand}"
                        IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Stretch" Classes="accent"/>

                <!-- 返回登录页 -->
                <Button Content="{loc:T Key=Common.Cancel}" Command="{Binding BackToLoginCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Border>

</UserControl>
