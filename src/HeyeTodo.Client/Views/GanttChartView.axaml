<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             x:Class="HeyeTodo.Client.Views.GanttChartView"
             x:Name="Root"
             x:DataType="vm:GanttChartViewModel">
    <Grid RowDefinitions="Auto,*">
        <Grid RowDefinitions="Auto,*">
            <Border Padding="20"
                    Background="{StaticResource SurfaceWarmBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="甘特图" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="以周为单位查看任务排期，红色任务表示时间冲突。"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Content="‹"
                            Command="{Binding PreviousWeekCommand}"
                            Classes.PanelAction="True"/>
                    <TextBlock Text="{Binding WeekTitle}"
                               MinWidth="210"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <Button Content="›"
                            Command="{Binding NextWeekCommand}"
                            Classes.PanelAction="True"/>
                    <Button Content="回到今天"
                            Command="{Binding GoToTodayCommand}"
                            Classes.NavigationCard="True"/>
                    <Button Content="刷新"
                            Command="{Binding RefreshCommand}"
                            Classes.NavigationCard="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="20"
                Background="{StaticResource SurfaceWarmBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="180,784">
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource SoftBorderBrush}"
                            BorderThickness="0,0,1,1"
                            Padding="12"
                            CornerRadius="14,0,0,0">
                        <TextBlock Text="任务" FontWeight="SemiBold"/>
                    </Border>
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:GanttDayColumnViewModel">
                                <Border Width="112"
                                        Height="58"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource SoftBorderBrush}"
                                        BorderThickness="0,0,1,1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{Binding DayName}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding DateText}" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid Grid.Row="1">
                    <TextBlock Text="没有可显示的任务，先在任务面板创建一个任务吧。"
                               IsVisible="{Binding HasNoTasks}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid Width="964" Height="{Binding ContentHeight}">
                            <ItemsControl ItemsSource="{Binding Bars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:GanttTaskBarViewModel">
                                        <Grid Width="964" Height="{Binding RowHeight}">
                                            <Border Width="180"
                                                    Height="{Binding RowHeight}"
                                                    Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource SoftBorderBrush}"
                                                    BorderThickness="0,0,1,1"
                                                    Padding="12,0">
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextDecorations="{Binding Task.TitleTextDecorations}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                            </Border>
                                            <Border Canvas.Left="180"
                                                    Margin="180,0,0,0"
                                                    Width="784"
                                                    Height="{Binding RowHeight}"
                                                    Background="#26FFFFFF"
                                                    BorderBrush="{StaticResource SoftBorderBrush}"
                                                    BorderThickness="0,0,0,1"/>
                                            <Border Margin="{Binding Left},0,0,0"
                                                    Width="{Binding Width}"
                                                    Height="30"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Padding="10,0"
                                                    CornerRadius="15"
                                                    Background="{Binding Background}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    Opacity="{Binding Opacity}"
                                                    PointerPressed="OnGanttBarPointerPressed"
                                                    PointerReleased="OnGanttBarPointerReleased">
                                                <ToolTip.Tip>
                                                    <Border Padding="12"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            BorderBrush="{StaticResource SoftBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <StackPanel Spacing="5">
                                                            <TextBlock Text="{Binding TooltipTitle}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding TooltipTimeRange}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding TooltipAssignee}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="{Binding TooltipUrgency}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ToolTip.Tip>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Text="{Binding LeftMarker}"
                                                               IsVisible="{Binding HasLeftMarker}"
                                                               Margin="0,0,4,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding Foreground}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DisplayText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               TextDecorations="{Binding Task.TitleTextDecorations}"
                                                               Foreground="{Binding Foreground}"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border IsVisible="{Binding IsTodayInCurrentWeek}"
                                    Margin="{Binding TodayLineLeft},0,0,0"
                                    Width="2"
                                    Height="{Binding ContentHeight}"
                                    HorizontalAlignment="Left"
                                    Background="#FF7A45"
                                    Opacity="0.9"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#33000000"
                IsVisible="{Binding TaskPanel.IsDetailsOpen}">
            <Grid>
                <Border Width="400"
                        HorizontalAlignment="Right"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource SoftBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Margin="0">
                    <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="任务详情" FontSize="22" FontWeight="Bold"/>
                            <Button Grid.Column="1"
                                    Content="关闭"
                                    Command="{Binding TaskPanel.CloseDetailsCommand}"
                                    Classes.PanelAction="True"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding TaskPanel.SelectedTaskName}" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TaskPanel.SelectedTaskDescription}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding TaskPanel.SelectedTaskProjectName}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <Border Height="1" Background="{StaticResource SoftBorderBrush}"/>
                                <TextBlock Text="任务细节" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="开始时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding TaskPanel.SelectedTaskStartDate, Mode=TwoWay}"/>
                                <TextBlock Text="结束时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding TaskPanel.SelectedTaskEndDate, Mode=TwoWay}"/>
                                <TextBlock Text="执行人" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox Text="{Binding TaskPanel.SelectedTaskAssigneeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="执行人"
                                         Classes.WarmInput="True"/>
                                <TextBlock Text="紧急程度" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <ComboBox ItemsSource="{Binding TaskPanel.UrgencyOptions}"
                                          SelectedItem="{Binding TaskPanel.SelectedTaskUrgency, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Classes.WarmSelect="True">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="vm:TaskUrgencyOptionViewModel">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="开始时间晚于结束时间，请确认时间是否正确"
                                           IsVisible="{Binding TaskPanel.HasSelectedTaskTimeWarning}"
                                           Foreground="#A6452E"
                                           TextWrapping="Wrap"/>
                                <Border Height="1" Background="{StaticResource SoftBorderBrush}"/>
                                <TextBlock Text="删除任务后当前阶段无法撤销。" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <Button Content="删除任务"
                                        Command="{Binding TaskPanel.RequestDeleteTaskCommand}"
                                        Classes.DangerAction="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="2"
                Background="#66000000"
                IsVisible="{Binding TaskPanel.IsDeleteConfirmOpen}">
            <Border Width="380"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock Text="确认删除任务？" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="确定要删除这个任务吗？这个操作当前无法撤销。" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="取消" Command="{Binding TaskPanel.CancelDeleteTaskCommand}"/>
                        <Button Content="删除" Command="{Binding TaskPanel.ConfirmDeleteTaskCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
