<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             x:Class="HeyeTodo.Client.Views.TaskPanelView"
             x:Name="Root"
             x:DataType="vm:TaskPanelViewModel">
    <Grid RowDefinitions="1*,3*">
        <Border Padding="20"
                Background="{StaticResource SurfaceWarmBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Grid RowDefinitions="Auto,*" RowSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="任务面板" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="当前任务、项目和任务细节会通过持久化系统自动保存。"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="2*,Auto,Auto,Auto,220" ColumnSpacing="12" VerticalAlignment="Center">
                    <TextBox PlaceholderText="搜索任务（暂未启用）"
                             VerticalAlignment="Center"
                             Classes.WarmInput="True"/>
                    <Button Grid.Column="1"
                            Content="搜索"
                            Command="{Binding SubmitSearchCommand}"
                            Classes.NavigationCard="True"/>
                    <Button Grid.Column="2"
                            Content="刷新排序"
                            Command="{Binding RefreshTasksCommand}"
                            Classes.NavigationCard="True"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
                        <Button Content="新建项目"
                                Command="{Binding OpenCreateProjectDialogCommand}"
                                Classes.NavigationCard="True"/>
                        <Button Content="新建任务"
                                Command="{Binding OpenCreateTaskDialogCommand}"
                                Classes.NavigationCard="True"/>
                    </StackPanel>
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding ProjectFilters}"
                              SelectedItem="{Binding SelectedProjectFilter}"
                              HorizontalAlignment="Stretch"
                              Classes.WarmSelect="True">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:ProjectFilterViewModel">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Border Padding="20"
                    Background="{StaticResource SurfaceWarmBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="任务栏" FontSize="22" FontWeight="SemiBold"/>
                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="还没有任务，先创建一个项目或任务吧。"
                                   IsVisible="{Binding HasNoVisibleTasks}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding VisibleTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TaskItemViewModel">
                                        <Border Margin="0,0,0,10"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource SoftBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Opacity="{Binding CardOpacity}"
                                                PointerEntered="OnTaskCardPointerEntered"
                                                PointerExited="OnTaskCardPointerExited"
                                                PointerPressed="OnTaskCardPointerPressed"
                                                PointerReleased="OnTaskCardPointerReleased">
                                            <Grid Margin="14" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                <Button Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        CornerRadius="14"
                                                        Content="{Binding CompletionMark}"
                                                        FontSize="13"
                                                        Background="{Binding CheckBackground}"
                                                        Foreground="{Binding CheckForeground}"
                                                        BorderBrush="{Binding CheckBorderBrush}"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Command="{Binding DataContext.ToggleTaskCompletedCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        Classes.TaskCheck="True"/>
                                                <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextDecorations="{Binding TitleTextDecorations}"/>
                                                    <Border Height="1"
                                                            Background="{StaticResource SoftBorderBrush}"
                                                            Opacity="0.65"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ProjectName}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#33000000"
                IsVisible="{Binding IsDetailsOpen}">
            <Grid>
                <Border Width="400"
                        HorizontalAlignment="Right"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource SoftBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Margin="0">
                    <Grid RowDefinitions="Auto,*" Margin="20" RowSpacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="任务详情" FontSize="22" FontWeight="Bold"/>
                            <Button Grid.Column="1"
                                    Content="关闭"
                                    Command="{Binding CloseDetailsCommand}"
                                    Classes.PanelAction="True"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding SelectedTaskName}" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedTaskDescription}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedTaskProjectName}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <Border Height="1" Background="{StaticResource SoftBorderBrush}"/>
                                <TextBlock Text="任务细节" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="开始时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding SelectedTaskStartDate, Mode=TwoWay}"/>
                                <TextBlock Text="结束时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <CalendarDatePicker SelectedDate="{Binding SelectedTaskEndDate, Mode=TwoWay}"/>
                                <TextBlock Text="执行人" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox Text="{Binding SelectedTaskAssigneeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="执行人"
                                         Classes.WarmInput="True"/>
                                <TextBlock Text="紧急程度" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <ComboBox ItemsSource="{Binding UrgencyOptions}"
                                          SelectedItem="{Binding SelectedTaskUrgency, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Classes.WarmSelect="True">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="vm:TaskUrgencyOptionViewModel">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="开始时间晚于结束时间，请确认时间是否正确"
                                           IsVisible="{Binding HasSelectedTaskTimeWarning}"
                                           Foreground="#A6452E"
                                           TextWrapping="Wrap"/>
                                <Border Height="1" Background="{StaticResource SoftBorderBrush}"/>
                                <TextBlock Text="删除任务后当前阶段无法撤销。" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <Button Content="删除任务"
                                        Command="{Binding RequestDeleteTaskCommand}"
                                        Classes.DangerAction="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="2"
                Background="#66000000"
                IsVisible="{Binding IsCreateProjectDialogOpen}">
            <Border Width="420"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock Text="新建项目" FontSize="24" FontWeight="Bold"/>
                    <TextBox PlaceholderText="项目名称" Text="{Binding NewProjectName}"/>
                    <TextBox PlaceholderText="项目描述" Text="{Binding NewProjectDescription}" AcceptsReturn="True" MinHeight="90"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="取消" Command="{Binding CancelCreateProjectCommand}"/>
                        <Button Content="创建" Command="{Binding CreateProjectCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                Background="#66000000"
                IsVisible="{Binding IsCreateTaskDialogOpen}">
            <Border Width="520"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock Text="新建任务" FontSize="24" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding NewTaskProject}"
                              HorizontalAlignment="Stretch"
                              Classes.WarmSelect="True">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:ProjectItemViewModel">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox PlaceholderText="任务名称" Text="{Binding NewTaskName}" Classes.WarmInput="True"/>
                    <TextBox PlaceholderText="任务描述" Text="{Binding NewTaskDescription}" AcceptsReturn="True" MinHeight="80" Classes.WarmInput="True"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="开始时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <CalendarDatePicker SelectedDate="{Binding NewTaskStartDate, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="结束时间" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <CalendarDatePicker SelectedDate="{Binding NewTaskEndDate, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,180" ColumnSpacing="12">
                        <TextBox PlaceholderText="执行人" Text="{Binding NewTaskAssigneeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Classes.WarmInput="True"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding UrgencyOptions}"
                                  SelectedItem="{Binding NewTaskUrgency, Mode=TwoWay}"
                                  Classes.WarmSelect="True">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="vm:TaskUrgencyOptionViewModel">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="{Binding NewTaskTimeWarning}"
                               IsVisible="{Binding HasNewTaskTimeWarning}"
                               Foreground="#A6452E"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="取消" Command="{Binding CancelCreateTaskCommand}"/>
                        <Button Content="创建" Command="{Binding CreateTaskCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                Background="#66000000"
                IsVisible="{Binding IsDeleteConfirmOpen}">
            <Border Width="380"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock Text="确认删除任务？" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="确定要删除这个任务吗？这个操作当前无法撤销。" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="取消" Command="{Binding CancelDeleteTaskCommand}"/>
                        <Button Content="删除" Command="{Binding ConfirmDeleteTaskCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                Padding="10"
                Background="{StaticResource NavigationItemHoverBrush}"
                CornerRadius="12">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
