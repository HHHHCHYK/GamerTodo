<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             x:Class="HeyeTodo.Client.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
        <TextBlock Text="{loc:T Key=Nav.Settings}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <TextBlock Opacity="0.5" Text="— M1 placeholder —" HorizontalAlignment="Center"/>
    </StackPanel>

</UserControl>
