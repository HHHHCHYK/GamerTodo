<!-- 规划视图：上部分控件区（项目选择 + 提示词输入 + AI 建议生成），下部分左右分栏（排期建议 + 冲突问题） -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="HeyeTodo.Client.Views.PlanningView"
             x:DataType="vm:PlanningViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">

        <!-- ===== 顶部控件区 ===== -->
        <Border Padding="16" Background="{StaticResource CozyCardBrush}"
                BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
            <StackPanel Spacing="10">
                <!-- 页面标题 -->
                <TextBlock Text="{loc:T Key=Planning.Title}" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource CozyTextBrush}"/>
                <!-- 工具栏：项目选择、刷新、生成建议 -->
                <Grid ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="8">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProjectItemViewModel">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Content="{loc:T Key=Tasks.Refresh}" Command="{Binding RefreshCommand}"/>
                    <Button Grid.Column="2" Content="{loc:T Key=Planning.Generate}" Command="{Binding GenerateCommand}" Classes="accent"/>
                </Grid>
                <!-- AI 提示词输入：多行文本框 -->
                <TextBox Text="{Binding Prompt}" PlaceholderText="{loc:T Key=Planning.Prompt}"
                         AcceptsReturn="True" MinHeight="72"/>
                <!-- 当前使用的 AI 驱动标签 -->
                <TextBlock Text="{Binding DriverLabel}" Foreground="{StaticResource CozyTextMutedBrush}" FontSize="12"/>
                <!-- 汇总信息 / 错误消息 -->
                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource CozySuccessBrush}"
                           IsVisible="{Binding Summary, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CozyErrorBrush}"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
        </Border>

        <!-- ===== 下部分栏：左为排期建议，右为冲突问题 ===== -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="12">

            <!-- 排期建议卡片：带排名编号、日期范围、理由和评分 -->
            <Border Padding="16" Background="{StaticResource CozyCardBrush}"
                    BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                    <TextBlock Text="{loc:T Key=Planning.Suggestions}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource CozyTextBrush}"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Suggestions}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanningSuggestionViewModel">
                                <Border Padding="10" Margin="0,0,0,6"
                                        Background="{StaticResource CozyBgBrush}"
                                        BorderBrush="{StaticResource CozyBorderBrush}"
                                        BorderThickness="2" CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <!-- 排名编号圆角方块 -->
                                        <Border Background="{StaticResource CozyAccentBrush}"
                                                CornerRadius="6" Width="32" Height="32">
                                            <TextBlock Text="{Binding Rank}" FontSize="16" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{Binding DateRange}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CozyTextBrush}"/>
                                            <TextBlock Text="{Binding Reason}" FontSize="12"
                                                       Foreground="{StaticResource CozyTextMutedBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Score}" FontSize="11"
                                                       Foreground="{StaticResource CozyTextMutedBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 冲突/问题卡片：黄色底边高亮，显示错误码和描述 -->
            <Border Grid.Column="1" Padding="16" Background="{StaticResource CozyCardBrush}"
                    BorderBrush="{StaticResource CozyBorderBrush}" BorderThickness="2" CornerRadius="10">
                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                    <TextBlock Text="{loc:T Key=Planning.Issues}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource CozyTextBrush}"/>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Issues}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanningIssueViewModel">
                                <Border Padding="10" Margin="0,0,0,6"
                                        Background="{StaticResource CozyBgBrush}"
                                        BorderBrush="{StaticResource CozyWarning}"
                                        BorderThickness="0,0,0,2" CornerRadius="8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Code}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource CozyTextBrush}"/>
                                        <TextBlock Text="{Binding Message}" FontSize="12"
                                                   Foreground="{StaticResource CozyTextMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
