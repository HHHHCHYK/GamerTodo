<!-- 角色选择页面：居中卡片，提示用户选择开发者角色，支持跳过或继续 -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="HeyeTodo.Client.Views.RoleSelectionView"
             x:DataType="vm:RoleSelectionViewModel">

    <Border MaxWidth="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
        <StackPanel Spacing="16">
            <!-- 选择提示文本 -->
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{loc:T Key=Roles.SelectionPrompt}" TextWrapping="Wrap"/>

            <!-- 角色选项列表：CheckBox 多选 -->
            <ItemsControl ItemsSource="{Binding Options}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoleOption">
                        <CheckBox Margin="0,4"
                                  IsChecked="{Binding IsSelected}"
                                  Content="{Binding Label}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 底部操作按钮：跳过 / 继续 -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="{loc:T Key=Common.Skip}"     Command="{Binding SkipCommand}"/>
                <Button Content="{loc:T Key=Common.Continue}" Command="{Binding ContinueCommand}" Classes="accent"/>
            </StackPanel>
        </StackPanel>
    </Border>

</UserControl>
