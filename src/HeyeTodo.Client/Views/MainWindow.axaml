<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HeyeTodo.Client.ViewModels"
        x:Class="HeyeTodo.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="520"
        Background="{StaticResource AppBackgroundBrush}"
        Title="HeyeTodo">
    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0"
                Margin="16"
                Padding="9"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4"
                 VerticalAlignment="Center">
                    <TextBlock Text="HeyeTodo" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="暖色工作台" Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding NavigationItems}" Margin="0,28,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:NavigationItemViewModel">
                            <Button Classes.NavigationCard="True"
                                    Classes.selected="{Binding IsSelected}"
                                    Command="{Binding $parent[Window].DataContext.SelectNavigationItemCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="34,*" VerticalAlignment="Center">
                                    <Border Width="28" Height="28"
                                            CornerRadius="10"
                                            Background="#FFFFFB"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Padding="12"
                        Background="{StaticResource SurfaceWarmBrush}"
                        BorderBrush="{StaticResource SoftBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <TextBlock Text="框架已准备好，后续页面会从这里扩展。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,16,16,16"
                Padding="22"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="28">
            <ContentControl Content="{Binding Current}"/>
        </Border>
    </Grid>
</Window>
