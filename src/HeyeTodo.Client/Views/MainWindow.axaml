<!-- 应用主窗口：承载所有子视图的路由容器，右上角叠加调试信息面板 -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HeyeTodo.Client.ViewModels"
        xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="HeyeTodo.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100" Height="720"
        MinWidth="760" MinHeight="480"
        Title="{loc:T Key=App.Title}">

    <Grid>
        <!-- 主内容区域：由 ViewModel 的 Current 属性动态切换视图 -->
        <ContentControl Content="{Binding Current}" />

        <!-- 调试信息面板：固定在右上角，半透明深色背景 -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Padding="8"
                Background="#CC1F1A17" CornerRadius="6">
            <StackPanel Spacing="8" Width="520">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Debug" Command="{Binding ToggleDebugInfoCommand}"/>
                    <Button Content="Refresh" Command="{Binding RefreshDebugInfoCommand}" IsVisible="{Binding IsDebugInfoVisible}"/>
                </StackPanel>
                <TextBox Text="{Binding DebugInfo}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         MaxHeight="320" FontFamily="Consolas" FontSize="11"
                         IsVisible="{Binding IsDebugInfoVisible}"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
