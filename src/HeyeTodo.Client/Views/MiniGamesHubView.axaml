<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HeyeTodo.Client.ViewModels"
             xmlns:loc="using:HeyeTodo.Client.Infrastructure.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="HeyeTodo.Client.Views.MiniGamesHubView"
             x:DataType="vm:MiniGamesHubViewModel">

    <Border VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="420">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{loc:T Key=MiniGames.ComingSoon}" HorizontalAlignment="Center"/>
            <TextBlock Opacity="0.65" TextAlignment="Center" TextWrapping="Wrap" Text="{loc:T Key=MiniGames.Body}"/>
        </StackPanel>
    </Border>

</UserControl>
